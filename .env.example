# ==========================================
# PawTenant Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore
# ==========================================

# ---- Supabase (Public - Browser Safe) ----
# Get these from: Supabase Dashboard → Project Settings → API
VITE_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# ---- Stripe (Public - Browser Safe) ----
# Get this from: Stripe Dashboard → Developers → API Keys → Publishable Key
# Use pk_test_ for development, pk_live_ for production
VITE_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_key_here"
